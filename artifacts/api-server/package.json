{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "prestart": "pnpm run build",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test src/lib/channel-utils.test.mjs src/routes/channels.integration.test.mjs",
    "test:channels": "node --test src/lib/channel-utils.test.mjs src/routes/channels.integration.test.mjs",
    "generate:emoji-catalog": "node ./scripts/generate-emoji-catalog.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "libphonenumber-js": "^1.13.3",
    "livekit-server-sdk": "^2.15.3",
    "apn": "^2.2.0",
    "multer": "^2.1.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
