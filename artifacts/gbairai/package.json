{
  "name": "@workspace/gbairai",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN pnpm exec expo start --localhost --port $PORT",
    "start:mobile": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1) expo start --dev-client --host lan --clear",
    "start:local": "sh -c 'IP=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1); echo \"Metro LAN: exp://$IP:8081\"; echo \"API: EXPO_PUBLIC_API_BASE_URL (.env → Render)\"; REACT_NATIVE_PACKAGER_HOSTNAME=$IP expo start --go --host lan --clear'",
    "start:go": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1) expo start --go --host lan --clear",
    "api:dev": "pnpm --dir ../api-server run dev",
    "build": "node scripts/build.js",
    "serve": "node server/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eas:whoami": "eas whoami",
    "eas:ios:credentials": "eas credentials --platform ios",
    "eas:ios:device": "eas device:create",
    "eas:device:create": "eas device:create",
    "eas:build:ios:dev": "eas build --platform ios --profile development",
    "eas:build:ios:sim": "eas build --platform ios --profile development-simulator",
    "eas:build:android:dev": "eas build --platform android --profile development",
    "eas:build:list": "eas build:list",
    "eas:build:ios:preview": "eas build --platform ios --profile preview",
    "eas:build:ios:prod": "eas build --platform ios --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production"
  },
