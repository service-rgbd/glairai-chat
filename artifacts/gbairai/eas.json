{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://glairai-chat.onrender.com",
        "EXPO_PUBLIC_E2E_ENABLED": "true",
        "EXPO_PUBLIC_LIVEKIT_ENABLED": "true",
        "EXPO_PUBLIC_NATIVE_CALL_UI": "true",
        "EXPO_PUBLIC_VOIP_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_VOIP_JS_REGISTER": "true"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://glairai-chat.onrender.com",
        "EXPO_PUBLIC_E2E_ENABLED": "true",
        "EXPO_PUBLIC_LIVEKIT_ENABLED": "true",
        "EXPO_PUBLIC_NATIVE_CALL_UI": "true",
        "EXPO_PUBLIC_VOIP_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_VOIP_JS_REGISTER": "true"
      },
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium",
        "credentialsSource": "remote"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://glairai-chat.onrender.com",
        "EXPO_PUBLIC_E2E_ENABLED": "true",
        "EXPO_PUBLIC_LIVEKIT_ENABLED": "true",
        "EXPO_PUBLIC_NATIVE_CALL_UI": "true",
        "EXPO_PUBLIC_VOIP_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_VOIP_JS_REGISTER": "true"
      },
      "ios": {
        "resourceClass": "m-medium",
        "credentialsSource": "remote"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://glairai-chat.onrender.com",
        "EXPO_PUBLIC_E2E_ENABLED": "true",
        "EXPO_PUBLIC_LIVEKIT_ENABLED": "true",
        "EXPO_PUBLIC_NATIVE_CALL_UI": "true",
        "EXPO_PUBLIC_VOIP_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_VOIP_JS_REGISTER": "true"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "bundleIdentifier": "com.gbairai.chat"
      }
    }
  }
}
