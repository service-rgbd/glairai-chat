{
  "expo": {
    "name": "Gbairai",
    "slug": "gbairai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gbairai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gbairai.chat",
      "infoPlist": {
        "NSContactsUsageDescription": "Gbairai utilise vos contacts pour trouver les personnes déjà inscrites dans l'application.",
        "NSUserNotificationsUsageDescription": "Gbairai utilise les notifications pour vous prévenir des nouveaux messages.",
        "NSPhotoLibraryUsageDescription": "Gbairai utilise votre photothèque pour choisir une photo de profil.",
        "NSPhotoLibraryAddUsageDescription": "Gbairai peut enregistrer les photos et vidéos reçues dans votre galerie.",
        "NSCameraUsageDescription": "Gbairai utilise la caméra pour vos appels vidéo.",
        "NSMicrophoneUsageDescription": "Gbairai utilise le microphone pour vos appels audio et vidéo.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      },
      "bitcode": false
    },
    "android": {
      "package": "com.gbairai.chat",
      "backgroundColor": "#0F172A",
      "permissions": [
        "READ_CONTACTS",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "BLUETOOTH_CONNECT",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          }
        }
      ],
      "@config-plugins/react-native-webrtc",
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/incoming.wav"]
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "21470a01-a774-4883-a20f-c93291f225a8"
      }
    },
    "owner": "vini2427"
  }
}
