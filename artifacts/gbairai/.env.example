# Mode test (Expo Go) : code OTP visible à l'écran sur l'étape vérification
EXPO_PUBLIC_OTP_DEMO=true

# API Render (données réelles) — compatible avec le mode test ci-dessus :
EXPO_PUBLIC_API_BASE_URL=https://glairai-chat.onrender.com

# Production stricte (masquer le code OTP à l'écran) :
# EXPO_PUBLIC_OTP_DEMO=false
# Côté serveur Render : OTP_DEMO_CODE_ENABLED=true (ou redéployer l'API récente)

# Dev local Expo Go (Metro sur le LAN, API Render ci-dessus) :
#   cd artifacts/gbairai && pnpm run start:local
#   Scannez le QR avec l'app Expo Go (App Store).
# API locale optionnelle (uniquement si vous lancez pnpm run api:dev) :
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.66:5000

# Efface session + cache au prochain lancement
# EXPO_PUBLIC_BOOT_RESET=true

# Dev local avec assets Fluent Emoji servis par l'API :
# EXPO_PUBLIC_USE_LOCAL_EMOJIS=true

# --- Appels audio/vidéo (LiveKit + EAS dev build) ---
# Côté API Render (variables d'environnement) :
# LIVEKIT_URL=wss://votre-projet.livekit.cloud
# LIVEKIT_API_KEY=...
# LIVEKIT_API_SECRET=...
# Build EAS : EXPO_PUBLIC_LIVEKIT_ENABLED=true (déjà dans eas.json)

# --- Appels audio/vidéo (LiveKit) ---
# Les appels nécessitent un dev build EAS (pas Expo Go).
# Côté API (.env.local racine) : LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET
# Build EAS / appels natifs : activer LiveKit dans le bundle Metro
# EXPO_PUBLIC_LIVEKIT_ENABLED=true
# CallKit / ConnectionService (dev build EAS uniquement — Expo Go utilise des stubs)
# EXPO_PUBLIC_NATIVE_CALL_UI=true
# Push VoIP PushKit iOS — écran verrouillé + CallKit (rebuild EAS requis)
# EXPO_PUBLIC_VOIP_PUSH_ENABLED=true
# false = PushKit natif AppDelegate (recommandé). true = registerVoipToken JS.
# EXPO_PUBLIC_VOIP_JS_REGISTER=false
# react-native-keyboard-controller (optionnel — natif par défaut)
# EXPO_PUBLIC_KEYBOARD_CONTROLLER=false

# --- Chiffrement E2E (phase 1 — chats 1-à-1 texte) ---
# false = messages en clair (comportement actuel). true = gbairai-e2e-v1
# EXPO_PUBLIC_E2E_ENABLED=false
# Côté API Render : E2E_ENABLED=true (sinon POST /api/e2e/devices → 503)
# Revenir à l'état pré-E2E : git checkout pre-e2e-baseline -- .
# Voir docs/e2e/README.md

# --- Push VoIP iOS (API Render, optionnel) ---
# Certificat .p8 Apple Push Notifications (VoIP) :
# APNS_VOIP_KEY_ID=...
# APNS_VOIP_TEAM_ID=...
# APNS_VOIP_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_BUNDLE_ID=com.gbairai.chat
# APNS_VOIP_PRODUCTION=false
# Build dev client :
#   cd artifacts/gbairai && eas build -p ios --profile development
#   cd artifacts/gbairai && eas build -p android --profile development
# Lancer Metro pour dev build :
#   pnpm exec expo start --dev-client --lan

# --- EAS / Apple Developer ---
# Projet EAS : https://expo.dev/accounts/vini2427/projects/gbairai
# 1) Connecter le compte Apple (une fois, interactif) :
#   cd artifacts/gbairai && pnpm run eas:ios:credentials
#   Choisir : "All: Set up all required credentials" puis connexion Apple ID
# 2) Enregistrer votre iPhone pour les builds internes :
#   pnpm run eas:ios:device
# 3) Lancer le build iOS dev client :
#   pnpm run eas:build:ios:dev
